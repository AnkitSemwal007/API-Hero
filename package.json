{
  "name": "api-hero",
  "displayName": "API Hero",
  "description": "API Hero — REST/HTTP client for VS Code: author .api requests, manage collections and environments, authenticate safely, assert responses, import OpenAPI, and review run history.",
  "version": "0.5.0",
  "publisher": "ankitsemwal",
  "license": "MIT",
  "homepage": "https://github.com/AnkitSemwal007/API-Hero",
  "repository": {
    "type": "git",
    "url": "https://github.com/AnkitSemwal007/API-Hero.git"
  },
  "bugs": {
    "url": "https://github.com/AnkitSemwal007/API-Hero/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Testing",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "api hero",
    "rest client",
    "http client",
    "api testing",
    "openapi",
    "api collections",
    "http requests",
    "assertions",
    "http",
    "rest",
    "api",
    "vscode"
  ],
  "galleryBanner": {
    "color": "#0f766e",
    "theme": "dark"
  },
  "icon": "images/icon.png",
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "api",
        "aliases": [
          "API Hero",
          "api"
        ],
        "extensions": [
          ".api"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./images/api-light.svg",
          "dark": "./images/api-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "api",
        "scopeName": "source.api-runner",
        "path": "./syntaxes/api.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "api",
        "path": "./snippets/api.json"
      }
    ],
    "commands": [
      {
        "command": "apiRunner.runRequest",
        "title": "API Hero: Run Request",
        "enablement": "editorLangId == api"
      },
      {
        "command": "apiRunner.runRequestWithAssertions",
        "title": "API Hero: Run Request with Assertions",
        "enablement": "editorLangId == api"
      },
      {
        "command": "apiRunner.runFile",
        "title": "API Hero: Run File (Coming Soon)"
      },
      {
        "command": "apiRunner.login",
        "title": "API Hero: Login (Coming Soon)"
      },
      {
        "command": "apiRunner.logout",
        "title": "API Hero: Logout (Coming Soon)"
      },
      {
        "command": "apiRunner.switchEnvironment",
        "title": "API Hero: Switch Environment"
      },
      {
        "command": "apiRunner.manageEnvironments",
        "title": "API Hero: Manage Environments",
        "icon": "$(globe)"
      },
      {
        "command": "apiRunner.manageAuthProfiles",
        "title": "API Hero: Manage Auth Profiles",
        "icon": "$(key)"
      },
      {
        "command": "apiRunner.selectAuthentication",
        "title": "API Hero: Select Authentication Profile"
      },
      {
        "command": "apiRunner.refreshCollections",
        "title": "API Hero: Refresh Collections",
        "icon": "$(refresh)"
      },
      {
        "command": "apiRunner.filterCollections",
        "title": "API Hero: Filter Collections",
        "icon": "$(search)"
      },
      {
        "command": "apiRunner.revealActiveRequest",
        "title": "API Hero: Reveal Active Request",
        "icon": "$(target)"
      },
      {
        "command": "apiRunner.openCollectionRequest",
        "title": "API Hero: Open Request"
      },
      {
        "command": "apiRunner.focusCollections",
        "title": "API Hero: Focus Collections"
      },
      {
        "command": "apiRunner.runCollection",
        "title": "API Hero: Run Collection",
        "icon": "$(play)"
      },
      {
        "command": "apiRunner.runCollectionTests",
        "title": "API Hero: Run Collection Tests",
        "icon": "$(beaker)"
      },
      {
        "command": "apiRunner.runFolder",
        "title": "API Hero: Run Folder",
        "icon": "$(play)"
      },
      {
        "command": "apiRunner.runSelectedRequests",
        "title": "API Hero: Run Selected Requests",
        "icon": "$(play)"
      },
      {
        "command": "apiRunner.focusHistory",
        "title": "API Hero: Focus History"
      },
      {
        "command": "apiRunner.openHistoryEntry",
        "title": "API Hero: Open History Entry"
      },
      {
        "command": "apiRunner.rerunHistoryEntry",
        "title": "API Hero: Re-run History Entry",
        "icon": "$(play)"
      },
      {
        "command": "apiRunner.revealHistoryRequest",
        "title": "API Hero: Reveal Original Request",
        "icon": "$(go-to-file)"
      },
      {
        "command": "apiRunner.deleteHistoryEntry",
        "title": "API Hero: Delete History Entry",
        "icon": "$(trash)"
      },
      {
        "command": "apiRunner.clearHistory",
        "title": "API Hero: Clear History",
        "icon": "$(clear-all)"
      },
      {
        "command": "apiRunner.searchHistory",
        "title": "API Hero: Search History",
        "icon": "$(search)"
      },
      {
        "command": "apiRunner.refreshHistory",
        "title": "API Hero: Refresh History",
        "icon": "$(refresh)"
      },
      {
        "command": "apiRunner.importOpenApi",
        "title": "API Hero: Import OpenAPI Specification",
        "icon": "$(cloud-download)"
      },
      {
        "command": "apiRunner.createCollection",
        "title": "API Hero: Create Collection",
        "icon": "$(new-folder)"
      },
      {
        "command": "apiRunner.renameCollection",
        "title": "API Hero: Rename Collection"
      },
      {
        "command": "apiRunner.deleteCollection",
        "title": "API Hero: Delete Collection",
        "icon": "$(trash)"
      },
      {
        "command": "apiRunner.duplicateCollection",
        "title": "API Hero: Duplicate Collection"
      },
      {
        "command": "apiRunner.exportCollection",
        "title": "API Hero: Export Collection",
        "icon": "$(export)"
      },
      {
        "command": "apiRunner.importCollection",
        "title": "API Hero: Import Collection",
        "icon": "$(desktop-download)"
      },
      {
        "command": "apiRunner.createFolder",
        "title": "API Hero: New Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "apiRunner.renameFolder",
        "title": "API Hero: Rename Folder"
      },
      {
        "command": "apiRunner.deleteFolder",
        "title": "API Hero: Delete Folder",
        "icon": "$(trash)"
      },
      {
        "command": "apiRunner.duplicateFolder",
        "title": "API Hero: Duplicate Folder"
      },
      {
        "command": "apiRunner.createRequest",
        "title": "API Hero: New Request",
        "icon": "$(add)"
      },
      {
        "command": "apiRunner.renameRequest",
        "title": "API Hero: Rename Request"
      },
      {
        "command": "apiRunner.duplicateRequest",
        "title": "API Hero: Duplicate Request"
      },
      {
        "command": "apiRunner.deleteRequest",
        "title": "API Hero: Delete Request",
        "icon": "$(trash)"
      },
      {
        "command": "apiRunner.moveRequest",
        "title": "API Hero: Move Request"
      },
      {
        "command": "apiRunner.openWorkspace",
        "title": "API Hero: Open Existing Workspace",
        "icon": "$(folder-opened)"
      },
      {
        "command": "apiRunner.openRequestEditor",
        "title": "API Hero: Open Request Editor",
        "enablement": "editorLangId == api"
      }
    ],
    "customEditors": [
      {
        "viewType": "apiRunner.requestEditor",
        "displayName": "API Hero Request Editor",
        "selector": [
          {
            "filenamePattern": "*.api"
          }
        ],
        "priority": "default"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "apiRunner.login",
          "when": "false"
        },
        {
          "command": "apiRunner.logout",
          "when": "false"
        }
      ],
      "editor/context": [
        {
          "command": "apiRunner.runRequest",
          "when": "editorLangId == api && editorTextFocus",
          "group": "navigation@10"
        },
        {
          "command": "apiRunner.revealActiveRequest",
          "when": "editorLangId == api && editorTextFocus",
          "group": "navigation@11"
        }
      ],
      "view/title": [
        {
          "command": "apiRunner.createCollection",
          "when": "view == apiRunner.collections",
          "group": "navigation@1"
        },
        {
          "command": "apiRunner.importCollection",
          "when": "view == apiRunner.collections",
          "group": "navigation@2"
        },
        {
          "command": "apiRunner.importOpenApi",
          "when": "view == apiRunner.collections",
          "group": "navigation@3"
        },
        {
          "command": "apiRunner.createRequest",
          "when": "view == apiRunner.collections",
          "group": "navigation@4"
        },
        {
          "command": "apiRunner.filterCollections",
          "when": "view == apiRunner.collections",
          "group": "navigation@5"
        },
        {
          "command": "apiRunner.refreshCollections",
          "when": "view == apiRunner.collections",
          "group": "navigation@6"
        },
        {
          "command": "apiRunner.revealActiveRequest",
          "when": "view == apiRunner.collections",
          "group": "navigation@7"
        },
        {
          "command": "apiRunner.refreshHistory",
          "when": "view == apiRunner.history",
          "group": "navigation@1"
        },
        {
          "command": "apiRunner.searchHistory",
          "when": "view == apiRunner.history",
          "group": "navigation@2"
        },
        {
          "command": "apiRunner.clearHistory",
          "when": "view == apiRunner.history",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "apiRunner.runCollection",
          "when": "view == apiRunner.collections && viewItem =~ /^collection/",
          "group": "inline@1"
        },
        {
          "command": "apiRunner.runFolder",
          "when": "view == apiRunner.collections && viewItem =~ /^folder/",
          "group": "inline@1"
        },
        {
          "command": "apiRunner.runSelectedRequests",
          "when": "view == apiRunner.collections && viewItem =~ /^request/",
          "group": "inline@1"
        },
        {
          "command": "apiRunner.openCollectionRequest",
          "when": "view == apiRunner.collections && viewItem =~ /^request/",
          "group": "inline@2"
        },
        {
          "command": "apiRunner.createRequest",
          "when": "view == apiRunner.collections && viewItem == collection",
          "group": "inline@3"
        },
        {
          "command": "apiRunner.createRequest",
          "when": "view == apiRunner.collections && viewItem == folder",
          "group": "inline@3"
        },
        {
          "command": "apiRunner.runCollection",
          "when": "view == apiRunner.collections && viewItem =~ /^collection/",
          "group": "1_run"
        },
        {
          "command": "apiRunner.runFolder",
          "when": "view == apiRunner.collections && viewItem =~ /^folder/",
          "group": "1_run"
        },
        {
          "command": "apiRunner.runSelectedRequests",
          "when": "view == apiRunner.collections && viewItem =~ /^request/",
          "group": "1_run"
        },
        {
          "command": "apiRunner.openCollectionRequest",
          "when": "view == apiRunner.collections && viewItem =~ /^request/",
          "group": "2_open"
        },
        {
          "command": "apiRunner.createRequest",
          "when": "view == apiRunner.collections && viewItem == collection",
          "group": "3_new@1"
        },
        {
          "command": "apiRunner.createFolder",
          "when": "view == apiRunner.collections && viewItem == collection",
          "group": "3_new@2"
        },
        {
          "command": "apiRunner.createRequest",
          "when": "view == apiRunner.collections && viewItem == folder",
          "group": "3_new@1"
        },
        {
          "command": "apiRunner.createFolder",
          "when": "view == apiRunner.collections && viewItem == folder",
          "group": "3_new@2"
        },
        {
          "command": "apiRunner.renameCollection",
          "when": "view == apiRunner.collections && viewItem == collection",
          "group": "4_modify@1"
        },
        {
          "command": "apiRunner.duplicateCollection",
          "when": "view == apiRunner.collections && viewItem == collection",
          "group": "4_modify@2"
        },
        {
          "command": "apiRunner.exportCollection",
          "when": "view == apiRunner.collections && viewItem == collection",
          "group": "4_modify@3"
        },
        {
          "command": "apiRunner.deleteCollection",
          "when": "view == apiRunner.collections && viewItem == collection",
          "group": "4_modify@4"
        },
        {
          "command": "apiRunner.renameFolder",
          "when": "view == apiRunner.collections && viewItem == folder",
          "group": "4_modify@1"
        },
        {
          "command": "apiRunner.duplicateFolder",
          "when": "view == apiRunner.collections && viewItem == folder",
          "group": "4_modify@2"
        },
        {
          "command": "apiRunner.deleteFolder",
          "when": "view == apiRunner.collections && viewItem == folder",
          "group": "4_modify@3"
        },
        {
          "command": "apiRunner.duplicateRequest",
          "when": "view == apiRunner.collections && viewItem == request",
          "group": "4_modify@1"
        },
        {
          "command": "apiRunner.renameRequest",
          "when": "view == apiRunner.collections && viewItem == request",
          "group": "4_modify@2"
        },
        {
          "command": "apiRunner.moveRequest",
          "when": "view == apiRunner.collections && viewItem =~ /^request/",
          "group": "4_modify@3"
        },
        {
          "command": "apiRunner.deleteRequest",
          "when": "view == apiRunner.collections && viewItem =~ /^request/",
          "group": "4_modify@4"
        },
        {
          "command": "apiRunner.rerunHistoryEntry",
          "when": "view == apiRunner.history && viewItem == historyEntry",
          "group": "inline@1"
        },
        {
          "command": "apiRunner.revealHistoryRequest",
          "when": "view == apiRunner.history && viewItem == historyEntry",
          "group": "inline@2"
        },
        {
          "command": "apiRunner.deleteHistoryEntry",
          "when": "view == apiRunner.history && viewItem == historyEntry",
          "group": "inline@3"
        },
        {
          "command": "apiRunner.openHistoryEntry",
          "when": "view == apiRunner.history && viewItem == historyEntry",
          "group": "1_open"
        },
        {
          "command": "apiRunner.rerunHistoryEntry",
          "when": "view == apiRunner.history && viewItem == historyEntry",
          "group": "2_run"
        },
        {
          "command": "apiRunner.revealHistoryRequest",
          "when": "view == apiRunner.history && viewItem == historyEntry",
          "group": "2_run"
        },
        {
          "command": "apiRunner.deleteHistoryEntry",
          "when": "view == apiRunner.history && viewItem == historyEntry",
          "group": "3_modify"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "apiRunner",
          "title": "API Hero",
          "icon": "images/icon.png"
        }
      ]
    },
    "views": {
      "apiRunner": [
        {
          "id": "apiRunner.collections",
          "name": "Collections"
        },
        {
          "id": "apiRunner.history",
          "name": "History"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "apiRunner.collections",
        "contents": "No collections yet.\nCreate a collection, start a new request, or import an OpenAPI specification.\n\n[Create Collection](command:apiRunner.createCollection)\n[New Request](command:apiRunner.createRequest)\n[Import OpenAPI](command:apiRunner.importOpenApi)\n[Open Workspace](command:apiRunner.openWorkspace)"
      },
      {
        "view": "apiRunner.history",
        "contents": "No request history yet.\nRun a request to start building history.\n\n[Focus Collections](command:apiRunner.focusCollections)\n[Refresh History](command:apiRunner.refreshHistory)"
      }
    ],
    "keybindings": [
      {
        "command": "apiRunner.runRequest",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "editorLangId == api && editorTextFocus"
      }
    ],
    "configuration": {
      "title": "API Hero",
      "properties": {
        "apiRunner.logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warning",
            "error"
          ],
          "default": "info",
          "description": "Minimum severity written to the API Hero output channel."
        },
        "apiRunner.requestTimeout": {
          "type": "number",
          "default": 30000,
          "minimum": 0,
          "description": "Request timeout in milliseconds."
        },
        "apiRunner.maxResponseBytes": {
          "type": "number",
          "default": 10485760,
          "minimum": 0,
          "description": "Maximum buffered HTTP response body size in bytes. When exceeded during download, the request fails with RESPONSE_TOO_LARGE. Set to 0 for no limit."
        },
        "apiRunner.history.maxEntries": {
          "type": "number",
          "default": 1000,
          "minimum": 1,
          "maximum": 10000,
          "description": "Maximum number of request history entries to retain. Newest entries are kept when the limit is exceeded."
        },
        "apiRunner.variables.global": {
          "type": "array",
          "default": [],
          "description": "Global API Hero variables. Sensitive values are masked by language and response UI; use trusted user settings for storage.",
          "items": {
            "type": "object",
            "required": [
              "name",
              "value"
            ],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[A-Za-z_][A-Za-z0-9_.-]*$"
              },
              "value": {
                "type": "string"
              },
              "sensitive": {
                "type": "boolean",
                "default": false
              }
            },
            "additionalProperties": false
          }
        },
        "apiRunner.variables.workspace": {
          "type": "array",
          "default": [],
          "description": "Workspace API Hero variables. Do not commit sensitive values in workspace settings.",
          "items": {
            "type": "object",
            "required": [
              "name",
              "value"
            ],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[A-Za-z_][A-Za-z0-9_.-]*$"
              },
              "value": {
                "type": "string"
              },
              "sensitive": {
                "type": "boolean",
                "default": false
              }
            },
            "additionalProperties": false
          }
        },
        "apiRunner.environments": {
          "type": "array",
          "default": [],
          "description": "Named API Hero environments. Exactly one environment may be active.",
          "items": {
            "type": "object",
            "required": [
              "id",
              "name",
              "variables"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "variables": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "name",
                    "value"
                  ],
                  "properties": {
                    "name": {
                      "type": "string",
                      "pattern": "^[A-Za-z_][A-Za-z0-9_.-]*$"
                    },
                    "value": {
                      "type": "string"
                    },
                    "sensitive": {
                      "type": "boolean",
                      "default": false
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        },
        "apiRunner.activeEnvironment": {
          "type": "string",
          "description": "ID of the active named environment. Omit to use no environment."
        },
        "apiRunner.authentication.profiles": {
          "type": "array",
          "default": [],
          "description": "Named authentication profile metadata. Secret sources are stored in VS Code SecretStorage; literal sources require unsafe: true.",
          "items": {
            "type": "object",
            "required": [
              "id",
              "providerId"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "label": {
                "type": "string"
              },
              "providerId": {
                "type": "string",
                "enum": [
                  "none",
                  "basic",
                  "bearer",
                  "apiKey"
                ]
              },
              "username": {
                "type": "object",
                "required": [
                  "kind"
                ],
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": [
                      "secret",
                      "variable",
                      "literal"
                    ]
                  },
                  "name": {
                    "type": "string"
                  },
                  "value": {
                    "type": "string"
                  },
                  "unsafe": {
                    "type": "boolean"
                  }
                },
                "additionalProperties": false,
                "allOf": [
                  {
                    "if": {
                      "required": [
                        "kind"
                      ],
                      "properties": {
                        "kind": {
                          "const": "literal"
                        }
                      }
                    },
                    "then": {
                      "required": [
                        "value",
                        "unsafe"
                      ],
                      "properties": {
                        "unsafe": {
                          "const": true
                        }
                      }
                    }
                  },
                  {
                    "if": {
                      "required": [
                        "kind"
                      ],
                      "properties": {
                        "kind": {
                          "const": "variable"
                        }
                      }
                    },
                    "then": {
                      "required": [
                        "name"
                      ]
                    }
                  }
                ]
              },
              "password": {
                "type": "object",
                "required": [
                  "kind"
                ],
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": [
                      "secret",
                      "variable",
                      "literal"
                    ]
                  },
                  "name": {
                    "type": "string"
                  },
                  "value": {
                    "type": "string"
                  },
                  "unsafe": {
                    "type": "boolean"
                  }
                },
                "additionalProperties": false,
                "allOf": [
                  {
                    "if": {
                      "required": [
                        "kind"
                      ],
                      "properties": {
                        "kind": {
                          "const": "literal"
                        }
                      }
                    },
                    "then": {
                      "required": [
                        "value",
                        "unsafe"
                      ],
                      "properties": {
                        "unsafe": {
                          "const": true
                        }
                      }
                    }
                  },
                  {
                    "if": {
                      "required": [
                        "kind"
                      ],
                      "properties": {
                        "kind": {
                          "const": "variable"
                        }
                      }
                    },
                    "then": {
                      "required": [
                        "name"
                      ]
                    }
                  }
                ]
              },
              "token": {
                "type": "object",
                "required": [
                  "kind"
                ],
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": [
                      "secret",
                      "variable",
                      "literal"
                    ]
                  },
                  "name": {
                    "type": "string"
                  },
                  "value": {
                    "type": "string"
                  },
                  "unsafe": {
                    "type": "boolean"
                  }
                },
                "additionalProperties": false,
                "allOf": [
                  {
                    "if": {
                      "required": [
                        "kind"
                      ],
                      "properties": {
                        "kind": {
                          "const": "literal"
                        }
                      }
                    },
                    "then": {
                      "required": [
                        "value",
                        "unsafe"
                      ],
                      "properties": {
                        "unsafe": {
                          "const": true
                        }
                      }
                    }
                  },
                  {
                    "if": {
                      "required": [
                        "kind"
                      ],
                      "properties": {
                        "kind": {
                          "const": "variable"
                        }
                      }
                    },
                    "then": {
                      "required": [
                        "name"
                      ]
                    }
                  }
                ]
              },
              "value": {
                "type": "object",
                "required": [
                  "kind"
                ],
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": [
                      "secret",
                      "variable",
                      "literal"
                    ]
                  },
                  "name": {
                    "type": "string"
                  },
                  "value": {
                    "type": "string"
                  },
                  "unsafe": {
                    "type": "boolean"
                  }
                },
                "additionalProperties": false,
                "allOf": [
                  {
                    "if": {
                      "required": [
                        "kind"
                      ],
                      "properties": {
                        "kind": {
                          "const": "literal"
                        }
                      }
                    },
                    "then": {
                      "required": [
                        "value",
                        "unsafe"
                      ],
                      "properties": {
                        "unsafe": {
                          "const": true
                        }
                      }
                    }
                  },
                  {
                    "if": {
                      "required": [
                        "kind"
                      ],
                      "properties": {
                        "kind": {
                          "const": "variable"
                        }
                      }
                    },
                    "then": {
                      "required": [
                        "name"
                      ]
                    }
                  }
                ]
              },
              "name": {
                "type": "string"
              },
              "location": {
                "type": "string",
                "enum": [
                  "header",
                  "query"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "apiRunner.import.maxFileBytes": {
          "type": "number",
          "default": 5242880,
          "minimum": 1,
          "maximum": 52428800,
          "description": "Maximum OpenAPI specification file size in bytes accepted by Import OpenAPI Specification. Larger files are rejected with a clear error."
        },
        "apiRunner.languageFeatures.hover": {
          "type": "boolean",
          "default": true,
          "description": "Enable documentation hovers in API Hero files."
        },
        "apiRunner.languageFeatures.outline": {
          "type": "boolean",
          "default": true,
          "description": "Enable request symbols in the Outline view for API Hero files."
        },
        "apiRunner.languageFeatures.diagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Enable lightweight syntax diagnostics in API Hero files."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "check": "tsc -p ./ --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "npm run compile && node ./scripts/run-unit-tests.mjs",
    "test:unit": "npm test",
    "test:coverage": "npm run compile && c8 --reporter=text-summary --reporter=text node ./scripts/run-unit-tests.mjs",
    "package": "vsce package",
    "vscode:prepublish": "npm run compile"
  },
